{
  "name": "@Blam-Network/blf",
  "version": "0.1.0",
  "description": "BLF chunk library for Halo (TypeScript)",
  "type": "module",
  "main": "./dist-cjs/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "haloreach/*": [
        "./dist/versions/haloreach/*"
      ],
      "halo3/*": [
        "./dist/versions/halo3/*"
      ],
      "halo3odst/*": [
        "./dist/versions/halo3odst/*"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "default": "./dist/index.js"
    },
    "./haloreach/*": {
      "types": "./dist/versions/haloreach/*.d.ts",
      "import": "./dist/versions/haloreach/*.js",
      "require": "./dist-cjs/versions/haloreach/*.js",
      "default": "./dist/versions/haloreach/*.js"
    },
    "./halo3/*": {
      "types": "./dist/versions/halo3/*.d.ts",
      "import": "./dist/versions/halo3/*.js",
      "require": "./dist-cjs/versions/halo3/*.js",
      "default": "./dist/versions/halo3/*.js"
    },
    "./halo3odst/*": {
      "types": "./dist/versions/halo3odst/*.d.ts",
      "import": "./dist/versions/halo3odst/*.js",
      "require": "./dist-cjs/versions/halo3odst/*.js",
      "default": "./dist/versions/halo3odst/*.js"
    }
  },
  "files": [
    "dist",
    "dist-cjs"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && node scripts/write-cjs-package-json.mjs",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "validate": "npm run check && npm run test && npm run typecheck",
    "release": "node scripts/release.mjs",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blam-Network/blf.git",
    "directory": "blf-ts"
  },
  "bugs": {
    "url": "https://github.com/Blam-Network/blf/issues"
  },
  "homepage": "https://github.com/Blam-Network/blf/tree/main/blf-ts#readme",
  "keywords": [
    "blf",
    "halo",
    "haloreach",
    "halo3",
    "halo3odst",
    "chunks",
    "binary",
    "fileshare"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@craftycodie/cstruct": "^1.0.0-alpha.10",
    "js-sha1": "^0.7.0",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@swc/core": "^1.15.33",
    "@types/node": "^22",
    "@types/pako": "^2.0.3",
    "typescript": "^5",
    "ultracite": "7.7.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.2.4"
  }
}

{
  "name": "@blamnetwork/blf",
  "version": "1.1.0-beta.2",
  "description": "BLF chunk library for Halo (TypeScript)",
  "type": "module",
  "main": "./dist-cjs/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "helpers": [
        "./dist/helpers/index.d.ts"
      ],
      "haloreach/*": [
        "./dist/versions/haloreach/*"
      ],
      "haloreach_mcc/*": [
        "./dist/versions/haloreach_mcc/*"
      ],
      "mcc/*": [
        "./dist/versions/mcc/*"
      ],
      "halo3/*": [
        "./dist/versions/halo3/*"
      ],
      "halo3odst/*": [
        "./dist/versions/halo3odst/*"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "default": "./dist/index.js"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "import": "./dist/helpers/index.js",
      "require": "./dist-cjs/helpers/index.js",
      "default": "./dist/helpers/index.js"
    },
    "./haloreach/*": {
      "types": "./dist/versions/haloreach/*.d.ts",
      "import": "./dist/versions/haloreach/*.js",
      "require": "./dist-cjs/versions/haloreach/*.js",
      "default": "./dist/versions/haloreach/*.js"
    },
    "./haloreach_mcc/*": {
      "types": "./dist/versions/haloreach_mcc/*.d.ts",
      "import": "./dist/versions/haloreach_mcc/*.js",
      "require": "./dist-cjs/versions/haloreach_mcc/*.js",
      "default": "./dist/versions/haloreach_mcc/*.js"
    },
    "./mcc/*": {
      "types": "./dist/versions/mcc/*.d.ts",
      "import": "./dist/versions/mcc/*.js",
      "require": "./dist-cjs/versions/mcc/*.js",
      "default": "./dist/versions/mcc/*.js"
    },
    "./halo3/*": {
      "types": "./dist/versions/halo3/*.d.ts",
      "import": "./dist/versions/halo3/*.js",
      "require": "./dist-cjs/versions/halo3/*.js",
      "default": "./dist/versions/halo3/*.js"
    },
    "./halo3odst/*": {
      "types": "./dist/versions/halo3odst/*.d.ts",
      "import": "./dist/versions/halo3odst/*.js",
      "require": "./dist-cjs/versions/halo3odst/*.js",
      "default": "./dist/versions/halo3odst/*.js"
    }
  },
  "files": [
    "dist",
    "dist-cjs"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && node scripts/write-cjs-package-json.mjs",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.build.cjs.json --noEmit",
    "test": "vitest run",
    "docs:gen": "node scripts/generate-docs-version-exports.mjs",
    "docs": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "validate": "npm run check && npm run test && npm run typecheck && npm run docs:build",
    "release": "node scripts/release.mjs",
    "prepack": "npm run build",
    "predocs": "npm run docs:gen",
    "predocs:build": "npm run docs:gen"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blam-Network/blf.git",
    "directory": "blf-ts"
  },
  "bugs": {
    "url": "https://github.com/Blam-Network/blf/issues"
  },
  "homepage": "https://blam-network.github.io/blf/",
  "keywords": [
    "blf",
    "halo",
    "haloreach",
    "halo3",
    "halo3odst"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@automapper/classes": "^8.8.1",
    "@automapper/core": "^8.8.1",
    "@craftycodie/cstruct": "^1.1.1",
    "js-sha1": "^0.7.0",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@swc/core": "^1.15.33",
    "@types/node": "^22",
    "@types/pako": "^2.0.3",
    "typescript": "^5",
    "ultracite": "7.7.0",
    "unplugin-swc": "^1.5.9",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  }
}
